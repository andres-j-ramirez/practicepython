import random as rd

def main():
    guesses = 1
    keep_going = True
    while keep_going == True:
        # Generate random number 1-9 inclusive
        a = rd.randint(1,9)

        right = False
        while right == False:
            # Ask user to guess the number
            b = int(input("Guess a number 1-9 inclusive: ").strip())

            # Tell them if they guessed low, high, or right

            if a < b:
                print("Too High!")
                guesses += 1
            elif a > b:
                print("Too Low!")
                guesses += 1
            else:
                print("You guessed just right!")
                right = True

        # Use "exit" to see if they want to keep playing
        keep_going = input("Press any key to continue, or type \"exit\" to quit: ").lower().strip()
        if keep_going == 'exit':
            keep_going = False
            print(f"You took {guesses} guess(es) in total")
        else:
            keep_going = True
            

if __name__ == "__main__":
    main()
